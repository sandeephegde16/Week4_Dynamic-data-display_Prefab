APP_DEBUG=false
DEMO_MODE=true
QUERY_MAX_ROWS=500

MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=your_database_name
MYSQL_USER=readonly_user
MYSQL_PASSWORD=

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Streamlit remains the shell; dynamic assistant UI blocks render through Prefab inline HTML when true.
ENABLE_PREFAB_EMBED=true

# Keep startup cheap. Schema suggestions use local heuristics unless this is explicitly enabled.
ENABLE_CLAUDE_SCHEMA_ANALYSIS=false
